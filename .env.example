# ---- Veritabanı ----
# Lokal Docker Compose ile: postgresql://sesac:sesac@localhost:5432/sesac?schema=public
DATABASE_URL=

# ---- Oturum / JWT imzalama anahtarı ----
# Güçlü, rastgele bir değer üretin: openssl rand -base64 32
NEXTAUTH_SECRET=

# ---- Web Push (VAPID) ----
# `npm run vapid` komutu ile üretebilirsiniz.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@susma.org

# ---- Uygulama ----
APP_URL=https://susma.org
