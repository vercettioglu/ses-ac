# ---- Veritabanı ----
# Lokal Docker Compose ile: postgresql://sesac:sesac@localhost:5432/sesac?schema=public
DATABASE_URL=

# ---- Oturum / JWT imzalama anahtarı ----
# Güçlü, rastgele bir değer üretin: openssl rand -base64 32
NEXTAUTH_SECRET=

# ---- Web Push (VAPID) ----
# `npm run vapid` komutu ile üretebilirsiniz.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@susma.org

# ---- Uygulama ----
APP_URL=https://susma.org

# ---- E-posta (self-hosted Postfix; düşük hacim: hoş geldin + şifre sıfırlama) ----
# Sunucuda yerel Postfix 127.0.0.1:25 dinler. Lokalde mail sunucusu yoksa gönderim
# best-effort olarak sessizce atlanır (akış bozulmaz).
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_FROM=Susma <noreply@susma.org>
